---
import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StreamingLinks from "../../components/StreamingLinks.astro";
import YouTubePlayer from "../../components/YouTubePlayer.astro";
import DonationCards from "../../components/DonationCards.astro";

export async function getStaticPaths() {
	const releases = await getCollection("releases");
	return releases.map((release) => ({
		params: { slug: release.slug },
		props: { release },
	}));
}

const { release } = Astro.props;
const { title, releaseDate, cover, coverAlt, summary, streaming, video, donation } = release.data;
const { Content } = await release.render();

const ogImage = await getImage({ src: cover, width: 1200, format: "jpeg" });
const coverURL = new URL(ogImage.src, Astro.site);
const structuredData = {
	"@context": "https://schema.org",
	"@type": "MusicAlbum",
	name: title,
	byArtist: { "@type": "MusicGroup", name: "Aaron Austin" },
	datePublished: releaseDate.toISOString().split("T")[0],
	image: coverURL,
	url: new URL(Astro.url.pathname, Astro.site),
};
---

<BaseLayout
	title={`${title} — Aaron Austin Music`}
	description={summary ?? `${title} — music by Aaron Austin.`}
	image={coverURL}
	imageWidth={ogImage.attributes.width}
	imageHeight={ogImage.attributes.height}
	type="music.album"
	structuredData={structuredData}
>
	<header class="flow text-center">
		<h1>{title}</h1>
		{summary && <p>{summary}</p>}
	</header>

	{
		cover && (
			<section class="flow text-center">
				<Image src={cover} alt={coverAlt ?? title} layout="constrained" width={600} />
			</section>
		)
	}

	<section class="flow text-center">
		<Content />
	</section>

	{
		streaming && (
			<section class="flow text-center">
				<StreamingLinks label="Listen Everywhere" {...streaming} />
			</section>
		)
	}

	{
		video && (
			<section class="flow text-center">
				<h2>Watch the Video</h2>
				<YouTubePlayer src={video.src} title={video.title ?? title} />
			</section>
		)
	}

	{
		donation && (
			<section class="flow text-center">
				<DonationCards heading={donation.heading} intro={donation.intro} orgs={donation.orgs} />
			</section>
		)
	}

	<section class="flow text-center">
		<div class="cluster flex-justify--center">
			<a class="outline" href="/">← All Releases</a>
		</div>
	</section>
</BaseLayout>

<style>
	header {
		margin-top: var(--space-xl);
	}
</style>
