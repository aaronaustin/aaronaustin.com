---
import "../styles/global.scss";
import HeaderAaron from "../svg/header-aaron.astro";
import HeaderAustin from "../svg/header-austin.astro";
const { title = "Music Site" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<nav class="site-nav container">
			<a href="/" class="site-logo" aria-label="Aaron Austin Music — Home">
				<HeaderAaron /><HeaderAustin />
			</a>
		</nav>
		<main class="container flow">
			<slot />
		</main>
		<footer class="site-footer container flow text-center">
			<p>© {new Date().getFullYear()} Aaron Austin</p>
		</footer>
	</body>
</html>
